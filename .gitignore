# === MQSim build artifacts ===
build/
*.o
*.obj
*.exe

# top-level built binary (regenerated by `make`)
/MQSim

# per-run binary copies (regenerated by README §2 / §3 staging snippets;
# used to isolate parallel output dirs since MQSim writes
# wl_scenario_<n>.xml next to the workload file)
sweep/runs/*/MQSim
exp2/runs/*/MQSim

# === Visual Studio leftovers ===
*.suo
*.user
.vs/
x64/
Debug/
Release/

# === Editor cruft ===
.vscode/
.idea/
*.swp
*~

# === Python ===
__pycache__/
*.pyc

# === OS junk ===
.DS_Store
Thumbs.db

# === Core dumps ===
core
core.*
